---
interface Props {
  storeName: string;
  adminName: string;
}

const { storeName, adminName } = Astro.props;

const pageTitleMap: Record<string, string> = {
  '/admin': 'Dashboard',
  '/admin/pesanan': 'Pesanan',
  '/admin/produk': 'Produk',
  '/admin/kategori': 'Kategori',
  '/admin/pengaturan': 'Pengaturan',
};

const path = Astro.url.pathname;
const pageTitle = pageTitleMap[path] ?? pageTitleMap[Object.keys(pageTitleMap).find((k) => k !== '/admin' && path.startsWith(k)) ?? ''] ?? 'Admin';
---

<header class="bg-bone border-b border-line sticky top-0 z-30 lg:z-10">
  <div class="h-20 flex items-center justify-between px-6 md:px-10 lg:px-12">
    <div class="flex items-center gap-4">
      <button id="sidebar-toggle" class="lg:hidden w-10 h-10 rounded-full border border-line flex items-center justify-center hover:bg-bone-soft" aria-label="Menu">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.8" d="M4 8h16M4 16h16" /></svg>
      </button>
      <div>
        <h1 class="font-display text-2xl md:text-3xl text-ink">{pageTitle}</h1>
        <p class="text-xs text-muted hidden sm:block">Selamat datang kembali, {adminName}</p>
      </div>
    </div>
    <div class="flex items-center gap-3">
      <a href="/" target="_blank" class="hidden md:inline-flex link-underline text-sm">
        Lihat Toko
      </a>
      <div class="w-10 h-10 rounded-full bg-clay flex items-center justify-center text-bone font-medium text-sm">
        {adminName.charAt(0).toUpperCase()}
      </div>
    </div>
  </div>
</header>
