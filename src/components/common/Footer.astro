---
import { getStoreSettings } from '../lib/store';

interface Props {
  settings: {
    storeName: string;
    address: string | null;
    whatsappNumber: string;
    email: string | null;
    instagramUrl: string | null;
    facebookUrl: string | null;
    tiktokUrl: string | null;
  };
}

const { settings } = Astro.props;
const year = new Date().getFullYear();
---

<footer class="bg-ink text-bone mt-auto relative overflow-hidden">
  <div class="absolute inset-0 opacity-[0.03] pointer-events-none" style="background-image: radial-gradient(circle at 1px 1px, white 1px, transparent 0); background-size: 24px 24px;"></div>

  <div class="container-page relative section">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16">
      <div class="lg:col-span-5">
        <div class="flex items-center gap-2.5 mb-6">
          <span class="w-9 h-9 rounded-full bg-bone flex items-center justify-center text-ink font-display text-lg">M</span>
          <span class="font-display text-2xl tracking-tight">{settings.storeName.replace('Ku', '')}<span class="text-clay">Ku</span></span>
        </div>
        <p class="text-bone/60 text-base leading-relaxed max-w-md mb-8">
          Mebel kayu premium dari Jepara — dibuat dengan tangan, dirancang untuk ruang yang bercerita. Setiap potong membawa karakter, setiap sambungan punya niat.
        </p>
        <div class="flex gap-2">
          {settings.instagramUrl && (
            <a href={settings.instagramUrl} target="_blank" rel="noopener" class="w-10 h-10 rounded-full border border-bone/20 flex items-center justify-center hover:bg-bone hover:text-ink hover:border-bone transition-all" aria-label="Instagram">
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
            </a>
          )}
          {settings.facebookUrl && (
            <a href={settings.facebookUrl} target="_blank" rel="noopener" class="w-10 h-10 rounded-full border border-bone/20 flex items-center justify-center hover:bg-bone hover:text-ink hover:border-bone transition-all" aria-label="Facebook">
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
            </a>
          )}
          {settings.tiktokUrl && (
            <a href={settings.tiktokUrl} target="_blank" rel="noopener" class="w-10 h-10 rounded-full border border-bone/20 flex items-center justify-center hover:bg-bone hover:text-ink hover:border-bone transition-all" aria-label="TikTok">
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.19-3.44-3.37-3.65-5.71-.02-.5-.03-1-.01-1.49.18-1.9 1.12-3.62 2.58-4.78 1.18-1.18 2.8-1.91 4.49-1.97.55-.02 1.1.02 1.64.13v4.15c-.31-.07-.63-.11-.95-.1-.76.02-1.52.34-2.03.91-.62.71-.86 1.72-.52 2.62.25.66.78 1.19 1.41 1.47.64.28 1.39.28 2.04.03.84-.34 1.45-1.09 1.6-1.99.05-.35.05-.71.05-1.07V0h.01z"/></svg>
            </a>
          )}
        </div>
      </div>

      <div class="lg:col-span-2">
        <h4 class="text-xs uppercase tracking-[0.2em] text-bone/50 mb-5 font-medium">Jelajahi</h4>
        <ul class="space-y-3 text-sm">
          <li><a href="/" class="text-bone/80 hover:text-bone transition-colors">Beranda</a></li>
          <li><a href="/produk" class="text-bone/80 hover:text-bone transition-colors">Koleksi</a></li>
          <li><a href="/tentang" class="text-bone/80 hover:text-bone transition-colors">Cerita Kami</a></li>
          <li><a href="/kontak" class="text-bone/80 hover:text-bone transition-colors">Kontak</a></li>
        </ul>
      </div>

      <div class="lg:col-span-2">
        <h4 class="text-xs uppercase tracking-[0.2em] text-bone/50 mb-5 font-medium">Kategori</h4>
        <ul class="space-y-3 text-sm">
          <li><a href="/kategori/kursi" class="text-bone/80 hover:text-bone transition-colors">Kursi</a></li>
          <li><a href="/kategori/meja" class="text-bone/80 hover:text-bone transition-colors">Meja</a></li>
          <li><a href="/kategori/lemari" class="text-bone/80 hover:text-bone transition-colors">Lemari</a></li>
          <li><a href="/kategori/sofa" class="text-bone/80 hover:text-bone transition-colors">Sofa</a></li>
        </ul>
      </div>

      <div class="lg:col-span-3">
        <h4 class="text-xs uppercase tracking-[0.2em] text-bone/50 mb-5 font-medium">Hubungi</h4>
        <ul class="space-y-4 text-sm">
          {settings.address && (
            <li class="flex items-start gap-3 text-bone/80">
              <svg class="w-4 h-4 mt-0.5 flex-shrink-0 text-clay" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              </svg>
              <span class="leading-relaxed">{settings.address}</span>
            </li>
          )}
          <li class="flex items-center gap-3 text-bone/80">
            <svg class="w-4 h-4 flex-shrink-0 text-clay" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            <a href={`https://wa.me/${settings.whatsappNumber}`} class="hover:text-bone transition-colors">+{settings.whatsappNumber}</a>
          </li>
          {settings.email && (
            <li class="flex items-center gap-3 text-bone/80">
              <svg class="w-4 h-4 flex-shrink-0 text-clay" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
              <a href={`mailto:${settings.email}`} class="hover:text-bone transition-colors">{settings.email}</a>
            </li>
          )}
        </ul>
      </div>
    </div>

    <div class="border-t border-bone/10 mt-20 pt-8 flex flex-col md:flex-row justify-between items-center gap-4">
      <p class="text-xs text-bone/40 tracking-wide">&copy; {year} {settings.storeName} — Crafted in Jepara</p>
      <a href="/admin/login" class="text-xs text-bone/40 hover:text-bone/80 transition-colors">Admin →</a>
    </div>
  </div>
</footer>
