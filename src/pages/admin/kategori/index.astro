---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { db, schema } from '../../../lib/db';
import { eq } from 'drizzle-orm';
---

<AdminLayout title="Kategori" active="/admin/kategori">
  <div class="space-y-6">
    <div class="flex items-center justify-between">
      <div>
        <h1 class="font-serif text-2xl font-bold text-primary">Kategori</h1>
        <p class="text-muted text-sm mt-1">Kelola kategori produk</p>
      </div>
      <button id="add-btn" class="btn-primary btn-sm">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
        </svg>
        Tambah Kategori
      </button>
    </div>

    <div class="card-static overflow-hidden">
      <div class="overflow-x-auto">
        <table class="w-full">
          <thead class="bg-muted-bg border-b border-border">
            <tr>
              <th class="text-left px-4 py-3 text-sm font-semibold text-primary">Nama</th>
              <th class="text-left px-4 py-3 text-sm font-semibold text-primary">Slug</th>
              <th class="text-center px-4 py-3 text-sm font-semibold text-primary">Status</th>
              <th class="text-right px-4 py-3 text-sm font-semibold text-primary">Aksi</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-border" id="categories-tbody"></tbody>
        </table>
      </div>
    </div>
  </div>

  <div id="modal" class="fixed inset-0 bg-black/50 z-50 hidden items-center justify-center px-4">
    <div class="card-static p-6 w-full max-w-md">
      <h2 class="font-serif text-lg font-bold text-primary mb-4" id="modal-title">Tambah Kategori</h2>
      <form id="category-form" class="space-y-4">
        <input type="hidden" id="categoryId" />
        <div>
          <label class="label">Nama Kategori *</label>
          <input type="text" id="categoryName" required class="input" />
        </div>
        <div>
          <label class="label">Deskripsi</label>
          <textarea id="categoryDescription" rows="2" class="input"></textarea>
        </div>
        <div>
          <label class="label">URL Gambar</label>
          <input type="text" id="categoryImage" class="input" placeholder="/uploads/..." />
        </div>
        <label class="flex items-center gap-2">
          <input type="checkbox" id="categoryActive" class="w-4 h-4 text-accent" checked />
          <span class="text-sm text-primary">Aktif</span>
        </label>
        <div class="flex gap-3">
          <button type="submit" class="btn-primary">Simpan</button>
          <button type="button" id="cancel-btn" class="btn-secondary">Batal</button>
        </div>
      </form>
    </div>
  </div>

  <script>
    const modal = document.getElementById('modal')!;
    const form = document.getElementById('category-form') as HTMLFormElement;

    async function loadCategories() {
      const res = await fetch('/api/admin/categories');
      const { data } = await res.json();
      const tbody = document.getElementById('categories-tbody')!;
      tbody.innerHTML = data.map((c: any) => `
        <tr class="hover:bg-wood-50">
          <td class="px-4 py-3">
            <div class="flex items-center gap-3">
              ${c.image ? `<img src="${c.image}" alt="${c.name}" class="w-8 h-8 rounded-lg object-cover" />` : '<div class="w-8 h-8 rounded-lg bg-muted-bg"></div>'}
              <span class="font-medium text-primary text-sm">${c.name}</span>
            </div>
          </td>
          <td class="px-4 py-3 text-sm text-muted">${c.slug}</td>
          <td class="px-4 py-3 text-center">
            <span class="badge ${c.isActive ? 'bg-green-100 text-green-700' : 'bg-muted-bg text-muted'}">${c.isActive ? 'Aktif' : 'Nonaktif'}</span>
          </td>
          <td class="px-4 py-3 text-right">
            <button data-edit="${c.id}" class="text-primary hover:text-accent inline-flex p-1.5">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" /></svg>
            </button>
            <button data-delete="${c.id}" class="text-destructive hover:text-red-700 inline-flex p-1.5">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" /></svg>
            </button>
          </td>
        </tr>
      `).join('');

      tbody.querySelectorAll('[data-edit]').forEach((btn) => {
        btn.addEventListener('click', () => {
          const cat = data.find((c: any) => c.id === (btn as HTMLElement).dataset.edit);
          if (cat) openModal(cat);
        });
      });

      tbody.querySelectorAll('[data-delete]').forEach((btn) => {
        btn.addEventListener('click', async () => {
          if (!confirm('Yakin hapus kategori ini?')) return;
          const id = (btn as HTMLElement).dataset.delete;
          const res = await fetch(`/api/admin/categories/${id}`, { method: 'DELETE' });
          const result = await res.json();
          if (result.error) {
            alert(result.error);
          } else {
            loadCategories();
          }
        });
      });
    }

    function openModal(cat?: any) {
      document.getElementById('modal-title')!.textContent = cat ? 'Edit Kategori' : 'Tambah Kategori';
      document.getElementById('categoryId')!.value = cat?.id || '';
      (document.getElementById('categoryName') as HTMLInputElement).value = cat?.name || '';
      (document.getElementById('categoryDescription') as HTMLTextAreaElement).value = cat?.description || '';
      (document.getElementById('categoryImage') as HTMLInputElement).value = cat?.image || '';
      (document.getElementById('categoryActive') as HTMLInputElement).checked = cat?.isActive ?? true;
      modal.classList.remove('hidden');
      modal.classList.add('flex');
    }

    function closeModal() {
      modal.classList.add('hidden');
      modal.classList.remove('flex');
      form.reset();
    }

    document.getElementById('add-btn')?.addEventListener('click', () => openModal());
    document.getElementById('cancel-btn')?.addEventListener('click', closeModal);
    modal.addEventListener('click', (e) => { if (e.target === modal) closeModal(); });

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const id = document.getElementById('categoryId')!.value;
      const data = {
        name: (document.getElementById('categoryName') as HTMLInputElement).value,
        description: (document.getElementById('categoryDescription') as HTMLTextAreaElement).value || null,
        image: (document.getElementById('categoryImage') as HTMLInputElement).value || null,
        isActive: (document.getElementById('categoryActive') as HTMLInputElement).checked,
      };

      if (id) {
        await fetch(`/api/admin/categories/${id}`, {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data),
        });
      } else {
        await fetch('/api/admin/categories', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data),
        });
      }

      closeModal();
      loadCategories();
    });

    loadCategories();
  </script>
</AdminLayout>
