---
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { db, schema } from '../../../lib/db';
import { desc } from 'drizzle-orm';
import { formatRupiah } from '../../../lib/money';

const orders = db.select().from(schema.orders).orderBy(desc(schema.orders.createdAt)).all();

const statusColors: Record<string, string> = {
  pending: 'bg-amber-100 text-amber-700',
  processing: 'bg-blue-100 text-blue-700',
  shipped: 'bg-purple-100 text-purple-700',
  completed: 'bg-green-100 text-green-700',
  cancelled: 'bg-red-100 text-red-700',
};
const statusLabels: Record<string, string> = {
  pending: 'Menunggu Konfirmasi',
  processing: 'Diproses',
  shipped: 'Dikirim',
  completed: 'Selesai',
  cancelled: 'Dibatalkan',
};
---

<AdminLayout title="Pesanan" active="/admin/pesanan">
  <div class="space-y-6">
    <div>
      <h1 class="font-serif text-2xl font-bold text-primary">Pesanan</h1>
      <p class="text-muted text-sm mt-1">Kelola pesanan toko</p>
    </div>

    <div class="card-static p-4">
      <div class="flex flex-col sm:flex-row gap-3">
        <input type="text" id="search-input" placeholder="Cari nama pelanggan..." class="input flex-1" />
        <select id="status-filter" class="input sm:w-48">
          <option value="">Semua Status</option>
          <option value="pending">Menunggu Konfirmasi</option>
          <option value="processing">Diproses</option>
          <option value="shipped">Dikirim</option>
          <option value="completed">Selesai</option>
          <option value="cancelled">Dibatalkan</option>
        </select>
      </div>
    </div>

    <div class="card-static overflow-hidden">
      <div class="overflow-x-auto">
        <table class="w-full">
          <thead class="bg-muted-bg border-b border-border">
            <tr>
              <th class="text-left px-4 py-3 text-sm font-semibold text-primary">Kode</th>
              <th class="text-left px-4 py-3 text-sm font-semibold text-primary">Pelanggan</th>
              <th class="text-right px-4 py-3 text-sm font-semibold text-primary">Total</th>
              <th class="text-center px-4 py-3 text-sm font-semibold text-primary">Status</th>
              <th class="text-left px-4 py-3 text-sm font-semibold text-primary">Tanggal</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-border" id="orders-tbody">
            {orders.map((order) => (
              <tr class="hover:bg-wood-50 cursor-pointer" onclick={`window.location.href='/admin/pesanan/${order.id}'`}>
                <td class="px-4 py-3">
                  <span class="font-medium text-primary text-sm">{order.orderCode}</span>
                </td>
                <td class="px-4 py-3">
                  <p class="text-sm font-medium text-primary">{order.customerName}</p>
                  <p class="text-xs text-muted">{order.customerPhone}</p>
                </td>
                <td class="px-4 py-3 text-sm font-semibold text-primary text-right">{formatRupiah(order.total)}</td>
                <td class="px-4 py-3 text-center">
                  <span class={`badge ${statusColors[order.status]}`}>{statusLabels[order.status]}</span>
                </td>
                <td class="px-4 py-3 text-sm text-muted">
                  {new Date(order.createdAt).toLocaleDateString('id-ID', { day: 'numeric', month: 'short', year: 'numeric' })}
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <script>
    const searchInput = document.getElementById('search-input') as HTMLInputElement;
    const statusFilter = document.getElementById('status-filter') as HTMLSelectElement;
    const tbody = document.getElementById('orders-tbody')!;

    function filterOrders() {
      const search = searchInput.value.toLowerCase();
      const status = statusFilter.value;
      tbody.querySelectorAll('tr').forEach((row) => {
        const name = row.querySelector('td:nth-child(2) p')?.textContent?.toLowerCase() ?? '';
        const statusBadge = row.querySelector('td:nth-child(4) span')?.textContent ?? '';
        const matchesSearch = !search || name.includes(search);
        const matchesStatus = !status || statusBadge.includes(status);
        (row as HTMLElement).style.display = matchesSearch && matchesStatus ? '' : 'none';
      });
    }

    searchInput.addEventListener('input', filterOrders);
    statusFilter.addEventListener('change', filterOrders);
  </script>
</AdminLayout>
