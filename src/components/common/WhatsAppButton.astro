---
interface Props {
  phone: string;
}

const { phone } = Astro.props;
const cleanPhone = phone.replace(/^0/, '62').replace(/[^0-9]/g, '');
---

<a
  href={`https://wa.me/${cleanPhone}?text=Halo%20${encodeURIComponent('MabelKu')}%2C%20saya%20ingin%20bertanya%20tentang%20produk%20mebel.`}
  target="_blank"
  rel="noopener"
  class="group fixed bottom-6 right-6 z-50 inline-flex items-center gap-3 pl-4 pr-5 py-3 bg-moss text-bone rounded-full shadow-lg hover:shadow-xl hover:-translate-y-0.5 transition-all duration-300"
  aria-label="Chat WhatsApp"
>
  <span class="relative flex items-center justify-center w-9 h-9 rounded-full bg-bone/10 group-hover:bg-bone/20 transition-colors">
    <span class="absolute inset-0 rounded-full bg-bone/30 animate-ping opacity-60 group-hover:opacity-0"></span>
    <svg class="w-4.5 h-4.5 relative" fill="currentColor" viewBox="0 0 24 24">
      <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347" />
    </svg>
  </span>
  <span class="hidden sm:inline text-sm font-medium">Chat dengan kami</span>
</a>
