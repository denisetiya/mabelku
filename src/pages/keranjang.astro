---
import MainLayout from '../layouts/MainLayout.astro';
import { formatRupiah } from '../lib/money';
---

<MainLayout title="Keranjang — MebelKu" description="Keranjang belanja Anda">
  <section class="container-page section-tight">
    <div class="max-w-5xl mx-auto">
      <header class="mb-12">
        <p class="eyebrow mb-4">Belanja Anda</p>
        <h1 class="display-lg text-balance">Keranjang.</h1>
      </header>

      <div id="cart-empty" class="py-20 text-center hidden">
        <div class="w-20 h-20 mx-auto mb-6 rounded-full bg-bone-soft flex items-center justify-center">
          <svg class="w-8 h-8 text-muted" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" />
          </svg>
        </div>
        <p class="font-display text-3xl mb-2">Keranjang kosong</p>
        <p class="text-muted mb-8">Belum ada karya yang Anda pilih.</p>
        <a href="/produk" class="btn-primary">Mulai Belanja</a>
      </div>

      <div id="cart-content" class="hidden">
        <div class="space-y-4" id="cart-items"></div>

        <div class="border-t border-line mt-12 pt-8 grid grid-cols-1 md:grid-cols-2 gap-8">
          <div class="space-y-3 text-sm">
            <div class="flex justify-between text-muted">
              <span>Subtotal</span>
              <span id="cart-subtotal">Rp0</span>
            </div>
            <div class="flex justify-between text-muted">
              <span>Pengiriman</span>
              <span>Dihitung setelah checkout</span>
            </div>
          </div>
          <div>
            <div class="flex justify-between items-baseline mb-2">
              <span class="font-display text-2xl text-ink">Total</span>
              <span class="font-display text-3xl text-ink" id="cart-total">Rp0</span>
            </div>
            <a href="/checkout" class="btn-primary btn-lg w-full mt-6">
              Lanjut ke Checkout
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </a>
            <a href="/produk" class="block text-center text-sm text-muted hover:text-ink transition-colors mt-4">
              ← Lanjut belanja
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <script>
    import { cart, updateQuantity, removeFromCart, getCartSubtotal } from '../components/cart/store';
    import { formatRupiah } from '../lib/money';
    import { getProductFallback } from '../lib/images-client';

    function renderCart() {
      const items = cart.get();
      const emptyEl = document.getElementById('cart-empty');
      const contentEl = document.getElementById('cart-content');
      const itemsEl = document.getElementById('cart-items');
      const subtotalEl = document.getElementById('cart-subtotal');
      const totalEl = document.getElementById('cart-total');

      if (items.length === 0) {
        emptyEl?.classList.remove('hidden');
        contentEl?.classList.add('hidden');
        return;
      }

      emptyEl?.classList.add('hidden');
      contentEl?.classList.remove('hidden');

      if (itemsEl) {
        itemsEl.innerHTML = items.map((item) => {
          const price = item.discountPrice && item.discountPrice > 0 ? item.discountPrice : item.price;
          const total = price * item.quantity;
          const img = item.mainImage || getProductFallback(item.slug);
          return `
            <div class="flex flex-col sm:flex-row gap-4 sm:gap-6 py-6 border-b border-line last:border-0">
              <a href="/produk/${item.slug}" class="w-full sm:w-32 aspect-square rounded-2xl overflow-hidden bg-bone-soft flex-shrink-0">
                <img src="${img}" alt="${item.name}" class="w-full h-full object-cover" />
              </a>
              <div class="flex-1 min-w-0 flex flex-col sm:flex-row sm:items-center gap-4">
                <div class="flex-1 min-w-0">
                  <a href="/produk/${item.slug}" class="font-display text-xl text-ink hover:text-clay transition-colors line-clamp-2">${item.name}</a>
                  <p class="text-sm text-muted mt-1">${formatRupiah(price)}</p>
                </div>
                <div class="flex items-center justify-between sm:gap-6">
                  <div class="inline-flex items-center border border-line rounded-full">
                    <button class="w-9 h-9 text-ink/70 hover:bg-bone-soft rounded-l-full transition-colors" data-qty-minus="${item.id}">−</button>
                    <input type="number" value="${item.quantity}" min="1" max="${item.stock}" data-qty-input="${item.id}" class="w-12 text-center border-0 focus:ring-0 bg-transparent text-sm font-medium" />
                    <button class="w-9 h-9 text-ink/70 hover:bg-bone-soft rounded-r-full transition-colors" data-qty-plus="${item.id}">+</button>
                  </div>
                  <p class="font-display text-xl text-ink sm:min-w-[7rem] sm:text-right">${formatRupiah(total)}</p>
                  <button class="text-muted hover:text-error transition-colors" data-remove="${item.id}" aria-label="Hapus">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                    </svg>
                  </button>
                </div>
              </div>
            </div>
          `;
        }).join('');

        itemsEl.querySelectorAll('[data-qty-minus]').forEach((btn) => {
          btn.addEventListener('click', () => {
            const id = (btn as HTMLElement).dataset.qtyMinus!;
            const input = itemsEl.querySelector(`[data-qty-input="${id}"]`) as HTMLInputElement;
            updateQuantity(id, parseInt(input.value, 10) - 1);
          });
        });

        itemsEl.querySelectorAll('[data-qty-plus]').forEach((btn) => {
          btn.addEventListener('click', () => {
            const id = (btn as HTMLElement).dataset.qtyPlus!;
            const input = itemsEl.querySelector(`[data-qty-input="${id}"]`) as HTMLInputElement;
            updateQuantity(id, parseInt(input.value, 10) + 1);
          });
        });

        itemsEl.querySelectorAll('[data-qty-input]').forEach((input) => {
          input.addEventListener('change', () => {
            const id = (input as HTMLInputElement).dataset.qtyInput!;
            updateQuantity(id, parseInt((input as HTMLInputElement).value, 10));
          });
        });

        itemsEl.querySelectorAll('[data-remove]').forEach((btn) => {
          btn.addEventListener('click', () => {
            removeFromCart((btn as HTMLElement).dataset.remove!);
          });
        });
      }

      const subtotal = getCartSubtotal();
      if (subtotalEl) subtotalEl.textContent = formatRupiah(subtotal);
      if (totalEl) totalEl.textContent = formatRupiah(subtotal);
    }

    cart.subscribe(renderCart);
    renderCart();
  </script>
</MainLayout>
