---
import { getCategoryFallbackImage } from '../../lib/images';

interface Props {
  category: {
    name: string;
    slug: string;
    image: string | null;
    description: string | null;
  };
}

const { category } = Astro.props;
const image = category.image || getCategoryFallbackImage(category.slug);
---

<a
  href={`/kategori/${category.slug}`}
  class="group block"
>
  <div class="relative aspect-[3/4] overflow-hidden rounded-2xl bg-bone-soft">
    <img
      src={image}
      alt={category.name}
      loading="lazy"
      class="w-full h-full object-cover transition-transform duration-700 ease-out group-hover:scale-105"
    />
    <div class="absolute inset-0 bg-gradient-to-t from-ink/85 via-ink/30 to-transparent"></div>
    <div class="absolute inset-x-0 bottom-0 p-6 text-bone">
      <div class="flex items-center justify-between gap-3">
        <div>
          <h3 class="font-display text-2xl md:text-3xl leading-tight mb-1">{category.name}</h3>
          {category.description && (
            <p class="text-sm text-bone/70 line-clamp-1 max-w-[200px]">{category.description}</p>
          )}
        </div>
        <div class="w-10 h-10 rounded-full border border-bone/30 flex items-center justify-center group-hover:bg-bone group-hover:text-ink group-hover:border-bone transition-all duration-300 flex-shrink-0">
          <svg class="w-4 h-4 transition-transform group-hover:translate-x-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </div>
      </div>
    </div>
  </div>
</a>
