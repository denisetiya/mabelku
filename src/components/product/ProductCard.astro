---
import { getEffectivePrice, getDiscountPercent, parseImages } from '../../lib/product';
import { getProductFallbackImage } from '../../lib/images';
import { formatRupiah } from '../../lib/money';

interface Props {
  product: {
    id: string;
    name: string;
    slug: string;
    price: number;
    discountPrice: number | null;
    stock: number;
    mainImage: string | null;
    images: string | null;
    isActive: boolean;
    categorySlug?: string | null;
  };
}

const { product } = Astro.props;
const effectivePrice = getEffectivePrice(product.price, product.discountPrice);
const discountPercent = getDiscountPercent(product.price, product.discountPrice);
const fallback = getProductFallbackImage(product.slug, product.categorySlug);
const image = product.mainImage || (parseImages(product.images)[0] ?? fallback);
const outOfStock = product.stock <= 0;
const lowStock = product.stock > 0 && product.stock <= 5;
---

<a
  href={`/produk/${product.slug}`}
  class="group block"
>
  <div class="relative aspect-[4/5] overflow-hidden rounded-2xl bg-bone-soft mb-4">
    <img
      src={image}
      alt={product.name}
      loading="lazy"
      class="w-full h-full object-cover transition-transform duration-700 ease-out group-hover:scale-105"
    />

    {discountPercent > 0 && (
      <div class="absolute top-3 left-3">
        <span class="pill-dark">-{discountPercent}%</span>
      </div>
    )}

    {outOfStock && (
      <div class="absolute inset-0 bg-bone/85 backdrop-blur-sm flex items-center justify-center">
        <span class="font-display text-xl text-ink">Stok Habis</span>
      </div>
    )}

    <div class="absolute bottom-3 left-3 right-3 flex items-end justify-between gap-2 opacity-0 translate-y-2 group-hover:opacity-100 group-hover:translate-y-0 transition-all duration-500">
      <span class="pill bg-bone/90 text-ink backdrop-blur-sm">Lihat Detail</span>
    </div>
  </div>

  <div class="px-1">
    <h3 class="font-display text-lg md:text-xl leading-snug text-ink line-clamp-2 mb-2 group-hover:text-clay transition-colors duration-300">
      {product.name}
    </h3>
    <div class="flex items-baseline gap-2">
      {discountPercent > 0 && (
        <span class="text-sm text-muted-soft line-through">{formatRupiah(product.price)}</span>
      )}
      <span class="font-display text-lg text-ink">{formatRupiah(effectivePrice)}</span>
    </div>
    {lowStock && (
      <p class="text-xs text-clay mt-1.5 font-medium">Sisa {product.stock} — hampir habis</p>
    )}
  </div>
</a>
